{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "shortstop/qa_report.schema.json",
  "title": "Stage 7 QA report artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "attempt", "score", "signals", "gaps"],
  "properties": {
    "verdict": { "enum": ["pass", "gap"] },
    "attempt": { "type": "integer", "minimum": 0 },
    "score": { "type": "number", "minimum": 0, "maximum": 100 },
    "signals": { "type": "object" },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["signal", "severity", "observed", "target", "suggested_fix"],
        "properties": {
          "signal": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["hard", "soft"] },
          "observed": {},
          "target": {},
          "suggested_fix": { "type": "string" }
        }
      }
    }
  }
}
