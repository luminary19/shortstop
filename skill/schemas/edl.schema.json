{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "shortstop/edl.schema.json",
  "title": "Stage 4 EDL artifact (keep-list)",
  "type": "object",
  "additionalProperties": false,
  "required": ["source", "keep", "removed", "notes"],
  "properties": {
    "source": { "type": "string", "minLength": 1 },
    "keep": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["start", "end", "reason"],
        "properties": {
          "start": { "type": "number", "minimum": 0 },
          "end": { "type": "number", "exclusiveMinimum": 0 },
          "reason": { "type": "string" }
        }
      }
    },
    "removed": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["start", "end", "kind", "reason"],
        "properties": {
          "start": { "type": "number", "minimum": 0 },
          "end": { "type": "number", "exclusiveMinimum": 0 },
          "kind": { "enum": ["filler", "pause", "false_start", "retake", "silence", "other"] },
          "reason": { "type": "string" }
        }
      }
    },
    "notes": { "type": "string" },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kept_s": { "type": "number", "minimum": 0 },
        "removed_s": { "type": "number", "minimum": 0 },
        "kept_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "removed_by_kind": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 }
        }
      }
    }
  }
}
